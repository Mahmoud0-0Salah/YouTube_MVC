@model outTube.Services.AdminDashboardStats
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Platform Dashboard";
}

<div class="row g-4">
    <!-- Main Stats Row -->
    <div class="col-12">
        <div class="studio-card-modern">
            <div class="card-header-modern">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-danger">analytics</span>
                    <span>Platform Overview</span>
                </div>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">System Operational</span>
            </div>
            <div class="row g-0">
                <div class="col-md-3 border-end border-white border-opacity-10">
                    <div class="stat-card-modern">
                        <div class="stat-value">@Model.TotalUsers.ToString("N0")</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                </div>
                <div class="col-md-3 border-end border-white border-opacity-10">
                    <div class="stat-card-modern">
                        <div class="stat-value">@Model.TotalVideos.ToString("N0")</div>
                        <div class="stat-label">Total Videos</div>
                    </div>
                </div>
                <div class="col-md-3 border-end border-white border-opacity-10">
                    <div class="stat-card-modern">
                        <div class="stat-value text-info">@Model.TotalViews.ToString("N0")</div>
                        <div class="stat-label">Total Views</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card-modern">
                        <div class="stat-value @(Model.PendingReports > 0 ? "text-danger" : "text-success")">@Model.PendingReports.ToString("N0")</div>
                        <div class="stat-label">Pending Reports</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Performance -->
    <div class="col-lg-8">
        <div class="studio-card-modern h-100">
            <div class="card-header-modern">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-info">trending_up</span>
                    <span>Top Performing Content</span>
                </div>
                <a asp-action="Videos" class="btn-studio-outline border-0 text-info">View All</a>
            </div>
            <div class="p-0">
                <table class="studio-table-modern w-100">
                    <thead>
                        <tr>
                            <th>Video Details</th>
                            <th>Engagement</th>
                            <th class="text-end">Performance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var video in Model.TopVideos.Take(5))
                        {
                            <tr>
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="position-relative">
                                            <img src="@video.ThumbnailUrl" width="80" height="45" class="rounded border border-white border-opacity-10" style="object-fit:cover; background:#000;" />
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="text-white fw-bold text-truncate" style="max-width: 240px; font-size: 14px;">@video.Title</span>
                                            <span class="text-secondary" style="font-size: 12px;">Published @(DateTime.Now.ToString("MMM dd, yyyy"))</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <div class="d-flex align-items-center gap-2 text-info">
                                        <span class="material-symbols-outlined" style="font-size: 18px;">bar_chart</span>
                                        <span class="fw-bold">@video.ViewCount.ToString("N0")</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25">High Growth</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- System Health -->
    <div class="col-lg-4">
        <div class="studio-card-modern h-100">
            <div class="card-header-modern">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-warning">speed</span>
                    <span>System Health</span>
                </div>
            </div>
            <div class="p-4">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary small">Server Load</span>
                        <span class="text-success small fw-bold text-uppercase">Optimal</span>
                    </div>
                    <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05);">
                        <div class="progress-bar bg-success" style="width: 24%"></div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary small">API Requests</span>
                        <span class="text-info small fw-bold">@((Model.TotalViews * 1.2).ToString("N0")) p/h</span>
                    </div>
                    <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05);">
                        <div class="progress-bar bg-info" style="width: 68%"></div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary small">Redundancy</span>
                        <span class="text-warning small fw-bold">Active</span>
                    </div>
                    <div class="progress" style="height: 6px; background: rgba(255,255,255,0.05);">
                        <div class="progress-bar bg-warning" style="width: 100%"></div>
                    </div>
                </div>

                <hr class="border-white border-opacity-10 my-4">

                <div class="d-grid gap-2">
                    <a asp-action="Reports" class="btn-studio-outline border-0 w-100 text-center py-2 bg-white bg-opacity-10 rounded-pill" style="color: white; font-size: 12px;">
                        Quick Policy Review
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .studio-table-modern td {
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }
    .studio-table-modern tr:last-child td {
        border-bottom: none;
    }
    .badge {
        font-weight: 700;
        letter-spacing: 0.5px;
    }
</style>
