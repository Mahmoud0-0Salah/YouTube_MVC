@model IEnumerable<outTube.Models.User>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>User Registry</h2>
    <div class="topbar-search" style="max-width: 400px;">
        <span class="material-symbols-outlined">search</span>
        <input type="text" id="userSearch" placeholder="Search users or handles..." onkeyup="filterUsers()" />
    </div>
</div>

<div class="studio-card">
    <div class="table-responsive">
        <table class="studio-table">
            <thead>
                <tr>
                    <th style="width: 40%">User</th>
                    <th>Permissions</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var isBanned = user.BansReceived.Any();
                    var defaultImg = "https://ui-avatars.com/api/?name=" + user.UserName + "&background=random";
                    var userImg = string.IsNullOrWhiteSpace(user.ImageUrl) ? defaultImg : user.ImageUrl;

                    <tr class="user-row">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@userImg" width="36" height="36" class="rounded-circle" alt="Avatar" />
                                <div class="d-flex flex-column">
                                    <span class="fw-medium search-target">@user.FirstName @user.LastName</span>
                                    <span class="text-secondary" style="font-size: 12px;">@@@user.UserName</span>
                                </div>
                            </div>
                        </td>
                        <td class="text-secondary small">Standard User</td>
                        <td class="text-secondary small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (isBanned)
                            {
                                <span class="d-flex align-items-center gap-1 text-danger" style="font-size: 13px;">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">block</span> Suspended
                                </span>
                            }
                            else
                            {
                                <span class="d-flex align-items-center gap-1 text-success" style="font-size: 13px;">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">check_circle</span> Active
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                @if (isBanned)
                                {
                                    <form asp-action="UnbanUser" method="post" style="display:inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn-studio-outline py-1 px-3" style="font-size: 12px;">Restore</button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn-studio-outline py-1 px-3" style="font-size: 12px; color: var(--text-secondary)" onclick="showBanModal('@user.Id', '@user.UserName')">Suspend</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Studio Styled Modal -->
<div class="modal fade" id="banModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Suspend @@<span id="modalUsername"></span>?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-secondary small mb-4">The user will lose access to all platform features until the suspension is lifted.</p>
                <form id="banForm" asp-action="BanUser" method="post">
                    <input type="hidden" id="banUserId" name="userId" />
                    <div class="mb-4">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Reason for suspension</label>
                        <textarea name="reason" rows="3" class="form-control bg-dark text-white border-secondary border-opacity-25" placeholder="Violation of community guidelines..." required></textarea>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn-studio-outline border-0 text-white" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-studio-outline border-0" style="color: var(--accent-blue)">Confirm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function filterUsers() {
        const query = document.getElementById('userSearch').value.toLowerCase();
        const rows = document.querySelectorAll('.user-row');
        
        rows.forEach(row => {
            const name = row.querySelector('.search-target').textContent.toLowerCase();
            const handle = row.querySelector('.text-secondary').textContent.toLowerCase();
            if (name.includes(query) || handle.includes(query)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function showBanModal(userId, username) {
        document.getElementById('banUserId').value = userId;
        document.getElementById('modalUsername').textContent = username;
        var myModal = new bootstrap.Modal(document.getElementById('banModal'));
        myModal.show();
    }
</script>
