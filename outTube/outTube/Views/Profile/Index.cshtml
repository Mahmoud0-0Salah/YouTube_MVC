@model outTube.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile - OurTube";
}

<div class="profile-container">
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-image-section">
                @{
                    var defaultImg = "https://ui-avatars.com/api/?name=" + Model.UserName + "&background=random";
                    var userImg = string.IsNullOrWhiteSpace(Model.ImageUrl) ? defaultImg : Model.ImageUrl;
                }
                <img src="@userImg" 
                     alt="Profile Picture" id="profile-img-preview" 
                     onerror="this.src='@defaultImg'" />
                <div class="image-overlay">
                    <label for="ImageFile" class="upload-btn">
                        <i class="fas fa-camera"></i>
                        <span>Change</span>
                    </label>
                </div>
            </div>
            <div class="profile-info-brief">
                <h2>@Model.FirstName @Model.LastName</h2>
                <p>@@@Model.UserName</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="profile-form">
            <input type="hidden" asp-for="Id" />
            <input asp-for="ImageFile" type="file" id="ImageFile" style="display:none" onchange="previewImage(event)" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-input" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-input" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-input" readonly />
                    <p class="input-hint">Email cannot be changed online for security.</p>
                </div>
                <div class="form-group">
                    <label asp-for="DateOfBirth"></label>
                    <input asp-for="DateOfBirth" class="form-input" id="profile-birth-picker" type="text" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Gender"></label>
                    <select asp-for="Gender" class="form-input" asp-items="Html.GetEnumSelectList<outTube.Models.Enums.Gender>()">
                        <option value="">Select Gender</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>

            <div class="profile-actions">
                <button type="submit" class="btn btn-primary save-btn">Save Changes</button>
            </div>
        </form>

        <script>
            document.addEventListener("DOMContentLoaded", function() {
                flatpickr("#profile-birth-picker", {
                    dateFormat: "Y-m-d",
                    maxDate: "today",
                    theme: "dark",
                    disableMobile: "true"
                });
            });

            function previewImage(event) {
                const input = event.target;
                if (input.files && input.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const dataUrl = e.target.result;
                        // Update preview on page
                        document.getElementById('profile-img-preview').src = dataUrl;
                        // Update navbar icon immediately
                        const navbarImg = document.getElementById('layout-profile-img');
                        if(navbarImg) {
                            navbarImg.src = dataUrl;
                        }
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            }
        </script>
    </div>
</div>

<style>
.profile-container {
    max-width: 900px;
    margin: 3rem auto;
    padding: 0 1.5rem;
}

.profile-card {
    background: #1a1a1a;
    border-radius: 2rem;
    padding: 3rem;
    box-shadow: 0 15px 40px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.08);
}

.profile-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

.profile-image-section {
    position: relative;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #ff0000;
    box-shadow: 0 0 20px rgba(255,0,0,0.3);
}

.profile-image-section img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: rgba(0,0,0,0.7);
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s;
}

.profile-image-section:hover .image-overlay {
    opacity: 1;
}

.upload-btn {
    cursor: pointer;
    color: #fff;
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.profile-info-brief h2 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    color: #fff;
}

.profile-info-brief p {
    color: #ff0000;
    font-family: monospace;
    font-size: 1.1rem;
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
}

.form-group {
    margin-bottom: 1.5rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.7rem;
    font-weight: 600;
    color: #ccc;
    font-size: 0.95rem;
}

.form-input {
    width: 100%;
    background: #000;
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    color: #fff;
    font-size: 1rem;
    transition: all 0.3s;
}

.form-input:focus {
    border-color: #ff0000;
    background: #0a0a0a;
}

.form-input[readonly] {
    opacity: 0.6;
    cursor: not-allowed;
}

.input-hint {
    font-size: 0.75rem;
    color: #666;
    margin-top: 0.5rem;
}

.profile-actions {
    margin-top: 3rem;
    display: flex;
    justify-content: flex-end;
}

.save-btn {
    padding: 1.1rem 2.5rem;
    background: #ff0000;
    color: #fff;
    border-radius: 1rem;
    font-weight: 700;
    font-size: 1.1rem;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(255,0,0,0.3);
}

.save-btn:hover {
    background: #cc0000;
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(255,0,0,0.4);
}

.alert-success {
    background: rgba(0, 255, 0, 0.1);
    color: #00ff00;
    padding: 1rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(0, 255, 0, 0.2);
}

@@media (max-width: 768px) {
    .form-grid {
        grid-template-columns: 1fr;
    }
    .profile-header {
        flex-direction: column;
        text-align: center;
    }
}
</style>
