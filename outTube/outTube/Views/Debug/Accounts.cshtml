@model IEnumerable<outTube.Models.User>
@{
    ViewData["Title"] = "Debug - All Accounts";
}

<div class="debug-container">
    <div class="debug-header">
        <div class="header-content">
            <h1>All Accounts Debug View</h1>
            <p>Full control over every user profile in the database</p>
        </div>
        <a asp-controller="Account" asp-action="Register" class="btn btn-add">
            <span class="material-symbols-outlined">person_add</span> Add New User
        </a>
    </div>

    <div class="debug-card">
        <table class="debug-table">
            <thead>
                <tr>
                    <th>Profile</th>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>ID & Info</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <img src="@(string.IsNullOrEmpty(user.ImageUrl) ? "https://ui-avatars.com/api/?name=" + user.UserName + "&background=random" : user.ImageUrl)" 
                                 class="debug-avatar" />
                        </td>
                        <td>
                            <div class="name-cell">
                                <span class="first-name">@user.FirstName</span>
                                <span class="last-name">@user.LastName</span>
                            </div>
                        </td>
                        <td><span class="username-tag">@@@user.UserName</span></td>
                        <td>@user.Email</td>
                        <td class="id-cell">
                            <code>@user.Id</code>
                            <br/>
                            <small class="joined-date">Joined: @user.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </td>
                        <td class="actions-cell">
                            <div class="action-buttons">
                                <button class="btn-icon edit" onclick="openEditModal('@user.Id', '@user.FirstName', '@user.LastName', '@user.UserName', '@user.Email')" title="Edit Profile">
                                    <span class="material-symbols-outlined">edit</span>
                                </button>
                                <button class="btn-icon password" onclick="openPasswordModal('@user.Id', '@user.UserName')" title="Reset Password">
                                    <span class="material-symbols-outlined">lock_reset</span>
                                </button>
                                <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user? This cannot be undone.')" style="display:inline;">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-icon delete" title="Delete User">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Edit User Modal -->
<div id="editModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Edit User Account</h2>
            <span class="close" onclick="closeModal('editModal')">&times;</span>
        </div>
        <form asp-action="UpdateUser" method="post" class="modal-form">
            <input type="hidden" name="id" id="edit-id" />
            <div class="form-row">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" name="firstName" id="edit-firstName" required />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" name="lastName" id="edit-lastName" required />
                </div>
            </div>
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="userName" id="edit-userName" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" id="edit-email" required />
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancel</button>
                <button type="submit" class="btn btn-save">Save Updates</button>
            </div>
        </form>
    </div>
</div>

<!-- Reset Password Modal -->
<div id="passwordModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Reset User Password</h2>
            <span class="close" onclick="closeModal('passwordModal')">&times;</span>
        </div>
        <form asp-action="ResetPassword" method="post" class="modal-form">
            <input type="hidden" name="id" id="pass-id" />
            <p class="modal-desc">Setting new password for: <strong id="pass-username"></strong></p>
            <div class="form-group">
                <label>New Password</label>
                <input type="password" name="newPassword" required minlength="6" />
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="closeModal('passwordModal')">Cancel</button>
                <button type="submit" class="btn btn-save">Change Password</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, fn, ln, un, em) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-firstName').value = fn;
        document.getElementById('edit-lastName').value = ln;
        document.getElementById('edit-userName').value = un;
        document.getElementById('edit-email').value = em;
        document.getElementById('editModal').style.display = 'flex';
    }

    function openPasswordModal(id, un) {
        document.getElementById('pass-id').value = id;
        document.getElementById('pass-username').innerText = '@@' + un;
        document.getElementById('passwordModal').style.display = 'flex';
    }

    function closeModal(modalId) {
        document.getElementById(modalId).style.display = 'none';
    }

    // Close on click outside
    window.onclick = function(event) {
        if (event.target.className === 'modal') {
            event.target.style.display = "none";
        }
    }
</script>

<style>
.debug-container {
    padding: 3rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
}

.debug-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid rgba(255,0,0,0.1);
}

.debug-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    color: #ff0000;
    margin-bottom: 0.5rem;
}

.debug-header p {
    color: #888;
    font-size: 1.1rem;
}

.btn-add {
    background: #ff0000;
    color: #fff;
    padding: 0.8rem 1.5rem;
    border-radius: 0.8rem;
    text-decoration: none !important;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    transition: all 0.3s;
}

.btn-add:hover {
    background: #cc0000;
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(255,0,0,0.4);
}

.debug-card {
    background: #111;
    border-radius: 2rem;
    padding: 1rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.05);
}

.debug-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 0.5rem;
}

.debug-table th {
    background: transparent;
    color: #666;
    text-align: left;
    padding: 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
}

.debug-table td {
    padding: 1.5rem 1rem;
    background: #1a1a1a;
    color: #ccc;
    vertical-align: middle;
}

.debug-table tr td:first-child { border-radius: 1rem 0 0 1rem; }
.debug-table tr td:last-child { border-radius: 0 1rem 1rem 0; }

.debug-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #333;
}

.username-tag {
    background: rgba(255,0,0,0.1);
    color: #ff0000;
    padding: 0.4rem 0.8rem;
    border-radius: 2rem;
    font-family: monospace;
    font-weight: 600;
}

.joined-date {
    color: #555;
    font-size: 0.8rem;
}

.id-cell code {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 0.4rem;
    color: #444;
}

/* Actions */
.action-buttons {
    display: flex;
    gap: 0.8rem;
}

.btn-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    background: #252525;
    color: #888;
}

.btn-icon:hover {
    transform: scale(1.1);
    color: #fff;
}

.btn-icon.edit:hover { background: #1c62b9; }
.btn-icon.password:hover { background: #ffaa00; }
.btn-icon.delete:hover { background: #ff0000; }

/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
}

.modal-content {
    background: #1a1a1a;
    padding: 2.5rem;
    border-radius: 2rem;
    width: 100%;
    max-width: 500px;
    border: 1px solid rgba(255,255,255,0.1);
    animation: slideIn 0.3s ease-out;
}

@@keyframes slideIn {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
}

.modal-header h2 { color: #ff0000; font-size: 1.5rem; }

.close {
    color: #666;
    font-size: 2rem;
    cursor: pointer;
}

.modal-form .form-group {
    margin-bottom: 1.5rem;
}

.modal-form .form-row {
    display: flex;
    gap: 1rem;
}

.modal-form label {
    display: block;
    color: #888;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
}

.modal-form input {
    width: 100%;
    background: #000;
    border: 1px solid #333;
    padding: 0.8rem 1rem;
    color: #fff;
    border-radius: 0.8rem;
    outline: none;
}

.modal-form input:focus { border-color: #ff0000; }

.modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 2rem;
}

.btn-secondary {
    background: #333;
    color: #fff;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 0.8rem;
    cursor: pointer;
}

.btn-save {
    background: #ff0000;
    color: #fff;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 0.8rem;
    font-weight: 700;
    cursor: pointer;
}
</style>
