@model outTube.ViewModels.Video.VideoCreateViewModel

@{
    ViewData["Title"] = "Upload Video";
}

<style>
/* YouTube Studio Upload Form Style - Amazing Red Theme */
.upload-container {
    max-width: 850px;
    margin: 40px auto;
    background-color: var(--nav-bg);
    border-radius: 16px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    border: 1px solid var(--border-color);
    padding: 40px;
    position: relative;
    overflow: hidden;
}

.upload-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: linear-gradient(90deg, #ff0000, #cc0000);
}

.upload-header {
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 20px;
    margin-bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.upload-header h2 {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
}

.upload-header h2::before {
    content: 'video_call';
    font-family: 'Material Symbols Outlined';
    color: #ff0000;
    font-size: 32px;
}

.form-group-custom {
    margin-bottom: 28px;
}

.form-label-custom {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 10px;
}

.form-control-custom {
    width: 100%;
    padding: 14px 18px;
    font-size: 16px;
    background-color: var(--bg-color);
    color: var(--text-color);
    border: 2px solid var(--search-border);
    border-radius: 10px;
    transition: all 0.3s ease;
}

.form-control-custom:focus {
    border-color: #ff0000;
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 0, 0, 0.15);
}

textarea.form-control-custom {
    resize: vertical;
    min-height: 140px;
}

.file-drop-area {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 45px 30px;
    min-height: 180px;
    border: 2px dashed var(--search-border);
    border-radius: 14px;
    background-color: var(--bg-color);
    transition: all 0.3s ease;
    text-align: center;
    cursor: pointer;
}

.file-drop-area:hover, .file-drop-area.dragover {
    background-color: rgba(255, 0, 0, 0.05);
    border-color: #ff0000;
}

.file-drop-icon {
    font-size: 42px;
    color: var(--text-secondary);
    margin-bottom: 18px;
    transition: all 0.3s ease;
}

.file-drop-area:hover .file-drop-icon {
    transform: translateY(-8px);
    color: #ff0000;
}

.file-msg {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-color);
}

.file-desc {
    font-size: 15px;
    color: var(--text-secondary);
    margin-top: 10px;
}

.file-input-actual {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    opacity: 0;
    cursor: pointer;
}

.btn-upload {
    background-color: #ff0000;
    color: #ffffff;
    border: none;
    border-radius: 24px;
    padding: 12px 32px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.btn-upload:hover {
    background-color: #cc0000;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 0, 0, 0.3);
}

.form-check-input {
    background-color: var(--bg-color);
    border: 2px solid var(--border-color);
    width: 48px !important;
    height: 24px !important;
}
.form-check-input:checked {
    background-color: #ff0000;
    border-color: #ff0000;
}
.btn-light {
    background-color: transparent;
    color: var(--text-color);
    border: 2px solid var(--border-color);
    font-weight: 600;
    transition: all 0.3s;
}
.btn-light:hover {
    background-color: var(--hover-bg);
    color: var(--text-color);
    border-color: var(--text-secondary);
}
</style>

<div class="upload-container">
    <div class="upload-header">
        <h2>Upload Video</h2>
        <a href="/Video/Index" class="btn btn-light" style="border-radius: 18px; padding: 6px 16px;">Cancel</a>
    </div>

    <form asp-action="Create" asp-controller="Video" method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-7 pe-md-4">
                <div class="form-group-custom">
                    <label asp-for="Title" class="form-label-custom">Title (required)</label>
                    <input asp-for="Title" class="form-control-custom" placeholder="Add a title that describes your video" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Description" class="form-label-custom">Description</label>
                    <textarea asp-for="Description" class="form-control-custom" placeholder="Tell viewers about your video"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                
                <div class="form-group-custom mt-4">
                    <div class="form-check form-switch ps-0 d-flex align-items-center gap-3">
                        <label asp-for="Visible" class="form-label-custom mb-0" style="cursor: pointer;">Publicly Visible</label>
                        <input asp-for="Visible" class="form-check-input ms-0 mt-0" type="checkbox" role="switch" checked style="width: 40px; height: 20px; cursor: pointer;" />
                    </div>
                </div>
            </div>

            <div class="col-md-5 mt-4 mt-md-0">
                <div class="form-group-custom">
                    <label class="form-label-custom">Video File</label>
                    <div class="file-drop-area">
                        <i class="file-drop-icon material-symbols-outlined">upload_file</i>
                        <span class="file-msg">Select video file</span>
                        <span class="file-desc mb-2">Drag and drop a file you want to upload</span>
                        <span class="btn mt-2" style="border-radius:18px; background-color: transparent; border: 2px solid #ff0000; color: #ff0000; font-weight: 600;">Browse Files</span>
                        <input asp-for="Source" type="file" class="file-input-actual" accept="video/mp4,video/webm,video/ogg" required onchange="showFileName(this, 'video-filename')" />
                    </div>
                    <div id="video-filename" class="mt-2 small fw-bold" style="color: #ff0000; font-size: 13px;"></div>
                </div>

                <div class="form-group-custom mt-4">
                    <label class="form-label-custom">Thumbnail</label>
                    <div class="file-drop-area" style="min-height: 120px; padding: 20px;">
                        <i class="file-drop-icon material-symbols-outlined" style="font-size: 32px; margin-bottom: 12px;">image</i>
                        <span class="file-msg" style="font-size: 14px;">Upload thumbnail</span>
                        <input asp-for="Thumbnail" type="file" class="file-input-actual" accept="image/jpeg,image/png,image/jpg" required onchange="showFileName(this, 'thumb-filename')" />
                    </div>
                    <div id="thumb-filename" class="mt-2 small fw-bold" style="color: #ff0000; font-size: 13px;"></div>
                </div>
            </div>
        </div>

        <div class="text-end mt-4 pt-4" style="border-top: 1px solid var(--border-color);">
            <button type="submit" class="btn-upload">NEXT</button>
        </div>
    </form>
</div>

<script>
    function showFileName(input, targetId) {
        var target = document.getElementById(targetId);
        if (input.files && input.files.length > 0) {
            target.textContent = "Selected: " + input.files[0].name;
            var dropArea = input.closest('.file-drop-area');
            dropArea.style.borderColor = "#ff0000";
            dropArea.style.backgroundColor = "rgba(255, 0, 0, 0.05)";
        } else {
            target.textContent = "";
        }
    }
</script>
