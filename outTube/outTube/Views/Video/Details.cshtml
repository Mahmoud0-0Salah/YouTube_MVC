@using Microsoft.AspNetCore.Identity
@model ourTube.ViewModels.Video.VideoDetailsViewModel
@inject UserManager<User> userManager
@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<style>
:root {
    --plyr-color-main: #ff0000;
}

/* Cinematic & Modern Red Theme */
.details-container {
    max-width: 1280px;
    margin: 20px auto;
    padding: 0 20px;
    animation: fadeScale 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@@keyframes fadeScale {
    from { opacity: 0; transform: scale(0.98) translateY(15px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.video-player-wrapper {
    border-radius: 24px;
    padding: 4px; /* Gradient border thickness */
    background: linear-gradient(45deg, #ff0000, #ff4d4d, #8b0000, #ff0000);
    background-size: 300% 300%;
    animation: neonBorderPulse 4s ease infinite;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 40px rgba(255, 0, 0, 0.4);
    margin-bottom: 30px;
    position: relative;
}

.video-player-inner {
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    position: relative;
    z-index: 1;
}

@@keyframes neonBorderPulse {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

video {
    width: 100%;
    max-height: 720px;
    display: block;
    outline: none;
    border-radius: 20px;
    accent-color: red;
}

.video-title {
    font-size: 24px;
    font-weight: 800;
    color: var(--text-color, #fff);
    margin: 15px 0 20px 0;
    line-height: 1.3;
}

.interaction-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 24px;
}

.channel-section {
    display: flex;
    align-items: center;
    gap: 15px;
}

.channel-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 12px rgba(255, 0, 0, 0.2);
}

.channel-info {
    display: flex;
    flex-direction: column;
}

.channel-name {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-color, #fff);
    margin: 0;
}

.btn-subscribe {
    background-color: var(--text-color, #0f0f0f);
    color: var(--bg-color, #fff);
    border: 1px solid var(--border-color, #ccc);
    border-radius: 20px;
    padding: 9px 20px;
    font-weight: 600;
    font-size: 14px;
    margin-left: 10px;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-subscribe:hover {
    background-color: #ff0000;
    color: #fff;
    border-color: #ff0000;
}

.action-buttons {
    display: flex;
    gap: 8px;
}

.action-group {
    display: flex;
    background: var(--nav-bg, rgba(20, 20, 20, 0.6));
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
}

.btn-action {
    display: flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--text-color, #fff);
    border: none;
    padding: 8px 16px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-action:hover {
    background: rgba(255, 0, 0, 0.1);
    color: #ff0000;
}

.divider {
    width: 1px;
    background: var(--border-color, rgba(255,255,255,0.1));
    margin: 6px 0;
}

.btn-single {
    border-radius: 24px;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
    background: var(--nav-bg, rgba(20, 20, 20, 0.6));
}

.description-box {
    background-color: var(--nav-bg, rgba(20, 20, 20, 0.6));
    border-radius: 16px;
    padding: 16px;
    color: var(--text-color, #fff);
    font-size: 15px;
    line-height: 1.5;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
    transition: background-color 0.3s;
}

.description-box:hover {
    background-color: var(--hover-bg, rgba(30, 30, 30, 0.8));
}

.meta-stats {
    font-weight: 700;
    margin-bottom: 8px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.meta-stats span {
    display: inline-block;
}

/* Comment Action Buttons */
.btn-comment-action {
    background: var(--nav-bg, rgba(20, 20, 20, 0.6));
    color: var(--text-color, #ccc);
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.1));
    border-radius: 12px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-comment-action:hover {
    background: rgba(255, 0, 0, 0.15);
    color: #ff0000;
    border-color: rgba(255, 0, 0, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 0, 0, 0.15);
}

.btn-comment-action:active {
    transform: translateY(0);
}

.edit-comment-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border-color, rgba(255,255,255,0.2));
    border-radius: 8px;
    color: var(--text-color, #fff);
    padding: 8px 12px;
    margin-bottom: 10px;
    outline: none;
    transition: border-color 0.3s, box-shadow 0.3s;
}

.edit-comment-input:focus {
    border-color: #ff0000;
    box-shadow: 0 0 8px rgba(255,0,0,0.3);
}
</style>

<div class="details-container">
    <!-- Video Player -->
    <div class="video-player-wrapper">
        <div class="video-player-inner">
            <video id="player" controls poster="@Model.Thumb" autoplay>
                <source src="@Model.VideoUrl" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </div>

    <!-- Video Title -->
    <h1 class="video-title">@Model.Title</h1>

    <!-- Interaction Row -->
    <div class="interaction-row">
        <div class="channel-section">
            <img src="@Model.Avatar" alt="@Model.Channel" class="channel-avatar" onerror="this.src='/images/default-avatar.png'" />
            <div class="channel-info">
                <p class="channel-name">@Model.Channel</p>
            </div>
            <button class="btn-subscribe">Subscribe</button>
        </div>

        <div class="action-buttons">
            <!-- Grouped Like/Dislike -->
            <div class="action-group">
                <button class="btn-action" id="likeBtn">
                    <span class="material-symbols-outlined">thumb_up</span>
                    <span id="likeText">Like</span>
                </button>
            </div>

            <!-- Individual Actions -->
            <button class="btn-action btn-single">
                <span class="material-symbols-outlined">share</span>
                Share
            </button>
            <button class="btn-action btn-single">
                <span class="material-symbols-outlined">bookmark_add</span>
                Save
            </button>
        </div>
    </div>

    <!-- Description Box -->
    <div class="description-box">
        <div class="meta-stats">
            <span>@Model.Views views</span>
            <span>• @Model.Time</span>
            @if (!string.IsNullOrEmpty(Model.Duration))
            {
                <span>• @Model.Duration</span>
            }
        </div>
        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)</p>
    </div>

    <!-- Comments Section -->
    <div class="comments-section" style="margin-top: 30px;">
        <h3 id="commentsCount" style="color: var(--text-color, #fff); margin-bottom: 20px;">@Model.NumOfComments Comment</h3>
        @if (User.Identity.IsAuthenticated)
        {
            var currentUser = await userManager.GetUserAsync(User);
            <div class="add-comment" style="display: flex; gap: 15px; margin-bottom: 30px;">
                <img src="@currentUser?.ImageUrl" alt="User" class="channel-avatar" style="width: 44px; height: 44px;" onerror="this.src='/images/default-avatar.png'" />
                <div style="flex-grow: 1;">
                    <input id="comment" type="text" placeholder="Add a comment..." style="width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--border-color, rgba(255,255,255,0.2)); color: var(--text-color, #fff); padding: 8px 0; outline: none; transition: border-color 0.3s;" onfocus="this.style.borderBottomColor='#ff0000'" onblur="this.style.borderBottomColor='var(--border-color, rgba(255,255,255,0.2))'" />
                    <div style="display: flex; justify-content: flex-end; margin-top: 10px; gap: 10px;">
                        <button class="btn-subscribe" style="border-radius: 18px;" onclick="sendCreatedComment()">Comment</button>
                    </div>
                </div>
            </div>
        }
        <div class="comments-list">
            <!-- Sample Comment -->
            @foreach(var comment in Model.Comments)
            {
                <div class="comment-item" id="comment-@comment.CommentId" style="display: flex; gap: 15px; margin-bottom: 24px;">
                    <img src="@comment.UserAvatar" alt="User" class="channel-avatar" style="width: 44px; height: 44px; border-radius: 50%;" />
                    <div style="flex-grow: 1;">
                        <div style="color: var(--text-color, #fff); font-weight: 600; font-size: 14px; margin-bottom: 4px;">@comment.UserName <span class="time-ago-text" data-date="@comment.UpdatedAt.ToString("o")" style="color: var(--text-muted, #aaa); font-weight: 400; font-size: 12px; margin-left: 8px;"></span></div>
                        <div class="comment-content" style="color: var(--text-color, #eee); font-size: 14px; line-height: 1.4; margin-bottom: 8px;">@comment.Content</div>
                        @if (User.Identity.IsAuthenticated)
                        {
                            var currentUserForCheck = await userManager.GetUserAsync(User);
                            if (currentUserForCheck?.Id == comment.UserId)
                            {
                                <div class="comment-actions" style="display: flex; gap: 10px; margin-top: 8px;">
                                    <button class="btn-comment-action" onclick="editComment('@comment.CommentId')">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">edit</span> Edit
                                    </button>
                                    <button class="btn-comment-action" onclick="deleteComment('@comment.CommentId')">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">delete</span> Delete
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js" integrity="sha512-kkMt8UThSmWcdXLYFaGZ/U6vyWSNLZMUWQ5SMeF80pGqrEkH5ei9D/3MbVQpB8p7D5C3A4vlX7BpsWTT2BfB6A==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    @{
        var jsUserId = "";
        if (User.Identity.IsAuthenticated)
        {
            var u = await userManager.GetUserAsync(User);
            if(u != null) { jsUserId = u.Id; }
        }
    }
    const currentUserId = '@jsUserId';

    function timeAgo(dateString) {
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return dateString;

        const seconds = Math.floor((new Date() - date) / 1000);
        if (seconds < 0) return "Just now"; // handles slight time sync issues

        let interval = seconds / 31536000;
        if (interval >= 1) return Math.floor(interval) + " years ago";
        interval = seconds / 2592000;
        if (interval >= 1) return Math.floor(interval) + " months ago";
        interval = seconds / 86400;
        if (interval >= 1) return Math.floor(interval) + " days ago";
        interval = seconds / 3600;
        if (interval >= 1) return Math.floor(interval) + " hours ago";
        interval = seconds / 60;
        if (interval >= 1) return Math.floor(interval) + " minutes ago";

        return seconds < 30 ? "Just now" : Math.floor(seconds) + " seconds ago";
    }

    // Hub connection for real-time comments
    var hub = new signalR.HubConnectionBuilder().withUrl("/commentsHub").build();
    hub.start().then(function () {
        console.log("Connection Success");
    });
    function sendCreatedComment() {
        const comment = {
            videoid: '@Model.Id',
            content: document.getElementById("comment").value,
            userid: null
        }
        document.getElementById("comment").value = ""
        hub.invoke("Create", comment)
    }

    function deleteComment(commentId) {
        if(confirm("Are you sure you want to delete this comment?")) {
            hub.invoke("Delete", commentId);
        }
    }

    function editComment(commentId) {
        var commentItem = document.getElementById("comment-" + commentId);
        var contentDiv = commentItem.querySelector('.comment-content');
        var originalText = contentDiv.innerText;

        contentDiv.innerHTML = `
            <input type="text" id="edit-input-${commentId}" value="${originalText}" class="edit-comment-input" />
            <div style="display: flex; gap: 10px;">
                <button class="btn-comment-action" onclick="saveEdit('${commentId}')">
                    <span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span> Save
                </button>
                <button class="btn-comment-action" onclick="cancelEdit('${commentId}', '${originalText.replace(/'/g, "\\'")}')">
                    <span class="material-symbols-outlined" style="font-size: 14px;">cancel</span> Cancel
                </button>
            </div>
        `;
        document.getElementById(`edit-input-${commentId}`).focus();
        commentItem.querySelector('.comment-actions').style.display = 'none';
    }

    function saveEdit(commentId) {
        var inputE = document.getElementById(`edit-input-${commentId}`);
        hub.invoke("Update", commentId, inputE.value);
    }

    function cancelEdit(commentId, originalText) {
        var commentItem = document.getElementById("comment-" + commentId);
        var contentDiv = commentItem.querySelector('.comment-content');
        contentDiv.innerText = originalText;
        commentItem.querySelector('.comment-actions').style.display = 'flex';
    }

    hub.on("ReceiveComment", function (obj) {
        console.log(obj);
        if(obj.videoId === '@Model.Id'){
            var div = document.createElement("div");
            div.className = "comment-item";
            div.style.display = "flex";
            div.style.gap = "15px";
            div.style.marginBottom = "24px";
            div.id = `comment-${obj.commentId}`;

            let actionBtns = '';
            if (currentUserId && obj.userId === currentUserId) {
                actionBtns = `
                    <div class="comment-actions" style="display: flex; gap: 10px; margin-top: 8px;">
                        <button class="btn-comment-action" onclick="editComment('${obj.commentId}')">
                            <span class="material-symbols-outlined" style="font-size: 14px;">edit</span> Edit
                        </button>
                        <button class="btn-comment-action" onclick="deleteComment('${obj.commentId}')">
                            <span class="material-symbols-outlined" style="font-size: 14px;">delete</span> Delete
                        </button>
                    </div>
                `;
            }

            div.innerHTML = `
                <img src="${obj.userAvatar}" alt="User" class="channel-avatar" style="width: 44px; height: 44px; border-radius: 50%;" />
                    <div style="flex-grow: 1;">
                        <div style="color: var(--text-color, #fff); font-weight: 600; font-size: 14px; margin-bottom: 4px;">${obj.userName} <span class="time-ago-text" data-date="${obj.updatedAt}" style="color: var(--text-muted, #aaa); font-weight: 400; font-size: 12px; margin-left: 8px;">${timeAgo(obj.updatedAt)}</span></div>
                        <div class="comment-content" style="color: var(--text-color, #eee); font-size: 14px; line-height: 1.4; margin-bottom: 8px;">${obj.content}</div>
                        ${actionBtns}
                    </div>`;
            document.querySelector('.comments-list').appendChild(div);
            document.querySelector('#commentsCount').innerText = parseInt(document.querySelector('#commentsCount').innerText) + 1 + " Comments";
        }
    });

    hub.on("ReceiveDeletedComment", function(commentId) {
        console.log(commentId);
        var commentElement = document.getElementById(`comment-${commentId}`);
        if(commentElement) {
            commentElement.remove();
            document.querySelector('#commentsCount').innerText = parseInt(document.querySelector('#commentsCount').innerText) - 1 + " Comments";
        }
    });

    hub.on("ReceiveUpdatedComment", function(obj) {
        var commentItem = document.getElementById("comment-" + obj.commentId);
        if(commentItem) {
            var contentDiv = commentItem.querySelector('.comment-content');
            contentDiv.innerText = obj.content;
            var actionsDiv = commentItem.querySelector('.comment-actions');
            if(actionsDiv) {
                actionsDiv.style.display = 'flex';
            }
            var timeSpan = commentItem.querySelector('.time-ago-text');
            if(timeSpan) {
                timeSpan.setAttribute('data-date', obj.updatedAt);
                timeSpan.innerText = timeAgo(obj.updatedAt);
            }
        }
    });

    document.addEventListener('DOMContentLoaded', () => {
        // Evaluate timeAgo for all existing comments
        document.querySelectorAll('.time-ago-text').forEach(el => {
            const dateStr = el.getAttribute('data-date');
            if (dateStr) {
                el.innerText = timeAgo(dateStr);
            }
        });

        const player = new Plyr('#player', {
            controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'captions', 'settings', 'pip', 'airplay', 'fullscreen']
        });

        const likeBtn = document.getElementById('likeBtn');
        const likeText = document.getElementById('likeText');
        let currentLikes = 0;

        if (likeBtn && likeText) {
            likeBtn.addEventListener('click', () => {
                if (currentLikes === 0) {
                    currentLikes = 1;
                    likeText.innerText = currentLikes;
                    likeBtn.style.color = '#ff0000';
                } else {
                    currentLikes = 0;
                    likeText.innerText = 'Like';
                    likeBtn.style.color = '';
                }
            });
        }
    });
</script>