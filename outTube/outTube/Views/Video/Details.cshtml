@model ourTube.ViewModels.Video.VideoGetViewModel

@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<style>
:root {
    --plyr-color-main: #ff0000;
}

/* Cinematic & Modern Red Theme */
.details-container {
    max-width: 1280px;
    margin: 20px auto;
    padding: 0 20px;
    animation: fadeScale 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@@keyframes fadeScale {
    from { opacity: 0; transform: scale(0.98) translateY(15px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.video-player-wrapper {
    border-radius: 24px;
    padding: 4px; /* Gradient border thickness */
    background: linear-gradient(45deg, #ff0000, #ff4d4d, #8b0000, #ff0000);
    background-size: 300% 300%;
    animation: neonBorderPulse 4s ease infinite;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 40px rgba(255, 0, 0, 0.4);
    margin-bottom: 30px;
    position: relative;
}

.video-player-inner {
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    position: relative;
    z-index: 1;
}

@@keyframes neonBorderPulse {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

video {
    width: 100%;
    max-height: 720px;
    display: block;
    outline: none;
    border-radius: 20px;
    accent-color: red;
}

.video-title {
    font-size: 24px;
    font-weight: 800;
    color: var(--text-color, #fff);
    margin: 15px 0 20px 0;
    line-height: 1.3;
}

.interaction-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 24px;
}

.channel-section {
    display: flex;
    align-items: center;
    gap: 15px;
}

.channel-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 12px rgba(255, 0, 0, 0.2);
}

.channel-info {
    display: flex;
    flex-direction: column;
}

.channel-name {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-color, #fff);
    margin: 0;
}

.btn-subscribe {
    background-color: var(--text-color, #0f0f0f);
    color: var(--bg-color, #fff);
    border: 1px solid var(--border-color, #ccc);
    border-radius: 20px;
    padding: 9px 20px;
    font-weight: 600;
    font-size: 14px;
    margin-left: 10px;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-subscribe:hover {
    background-color: #ff0000;
    color: #fff;
    border-color: #ff0000;
}

.action-buttons {
    display: flex;
    gap: 8px;
}

.action-group {
    display: flex;
    background: var(--nav-bg, rgba(20, 20, 20, 0.6));
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
}

.btn-action {
    display: flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--text-color, #fff);
    border: none;
    padding: 8px 16px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-action:hover {
    background: rgba(255, 0, 0, 0.1);
    color: #ff0000;
}

.divider {
    width: 1px;
    background: var(--border-color, rgba(255,255,255,0.1));
    margin: 6px 0;
}

.btn-single {
    border-radius: 24px;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
    background: var(--nav-bg, rgba(20, 20, 20, 0.6));
}

.description-box {
    background-color: var(--nav-bg, rgba(20, 20, 20, 0.6));
    border-radius: 16px;
    padding: 16px;
    color: var(--text-color, #fff);
    font-size: 15px;
    line-height: 1.5;
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
    transition: background-color 0.3s;
}

.description-box:hover {
    background-color: var(--hover-bg, rgba(30, 30, 30, 0.8));
}

.meta-stats {
    font-weight: 700;
    margin-bottom: 8px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.meta-stats span {
    display: inline-block;
}
</style>

<div class="details-container">
    <!-- Video Player -->
    <div class="video-player-wrapper">
        <div class="video-player-inner">
            <video id="player" controls poster="@Model.Thumb" autoplay>
                <source src="@Model.VideoUrl" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </div>

    <!-- Video Title -->
    <h1 class="video-title">@Model.Title</h1>

    <!-- Interaction Row -->
    <div class="interaction-row">
        <div class="channel-section">
            <img src="@Model.Avatar" alt="@Model.Channel" class="channel-avatar" onerror="this.src='/images/default-avatar.png'" />
            <div class="channel-info">
                <p class="channel-name">@Model.Channel</p>
            </div>
            <button class="btn-subscribe">Subscribe</button>
        </div>

        <div class="action-buttons">
            <!-- Grouped Like/Dislike -->
            <div class="action-group">
                <button class="btn-action">
                    <span class="material-symbols-outlined">thumb_up</span>
                    Like
                </button>
                <div class="divider"></div>
                <button class="btn-action" style="padding-left:12px; padding-right:12px;">
                    <span class="material-symbols-outlined">thumb_down</span>
                </button>
            </div>
            
            <!-- Individual Actions -->
            <button class="btn-action btn-single">
                <span class="material-symbols-outlined">share</span>
                Share
            </button>
            <button class="btn-action btn-single">
                <span class="material-symbols-outlined">bookmark_add</span>
                Save
            </button>
        </div>
    </div>

    <!-- Description Box -->
    <div class="description-box">
        <div class="meta-stats">
            <span>@Model.Views views</span>
            <span>• @Model.Time</span>
            @if (!string.IsNullOrEmpty(Model.Duration))
            {
                <span>• @Model.Duration</span>
            }
        </div>
        <p>Welcome to this amazing video! Support the channel by subscribing for more awesome content.</p>
    </div>
</div>

<script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const player = new Plyr('#player', {
            controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'captions', 'settings', 'pip', 'airplay', 'fullscreen']
        });
    });
</script>