@model ourTube.ViewModels.SearchViewModel
@{
    ViewData["Title"] = "Search Results - " + Model.Query;
    Layout = "_LayoutOUtTube";
}

<style>
    /* Video Grid */
    .video-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        row-gap: 40px;
        margin-top: 24px;
    }

    /* Video Card */
    .video-card {
        display: flex;
        flex-direction: column;
        cursor: pointer;
        background: transparent;
        text-decoration: none;
        color: inherit;
    }

    .thumbnail-container {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        background-color: var(--border-color);
    }
    .thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.2s ease-in-out;
    }
    .video-card:hover .thumbnail {
        transform: scale(1.02);
        border-radius: 0;
    }
    
    .duration {
        position: absolute;
        bottom: 8px;
        right: 8px;
        background-color: var(--badge-bg);
        color: var(--badge-text);
        padding: 3px 4px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
    }

    .video-info {
        display: flex;
        margin-top: 12px;
        gap: 12px;
    }
    .channel-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        margin-top: 2px;
    }
    .video-details {
        display: flex;
        flex-direction: column;
    }
    .video-title {
        font-size: 16px;
        font-weight: 500;
        color: var(--text-color);
        margin-bottom: 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4;
    }
    .channel-name {
        font-size: 14px;
        color: var(--text-secondary);
        margin-bottom: 2px;
        text-decoration: none;
    }
    .channel-name:hover {
        color: var(--text-color);
    }
    .video-meta {
        font-size: 14px;
        color: var(--text-secondary);
    }

    .section-header {
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 12px;
        margin-top: 32px;
        font-size: 20px;
        font-weight: 500;
        color: var(--text-color);
    }

    @@media (max-width: 500px) {
        .video-grid { grid-template-columns: 1fr; }
        .thumbnail-container { border-radius: 0; }
    }
</style>

<div class="px-2">
    @if (Model.Channels != null && Model.Channels.Any())
    {
        <h4 class="section-header">Channels</h4>
        <div class="row pt-3">
            @foreach (var channel in Model.Channels)
            {
                <partial name="_ChannelCard" model="channel" />
            }
        </div>
    }

    <h4 class="section-header">Videos</h4>
    @if (Model.Videos != null && Model.Videos.Any())
    {
        <div class="video-grid" id="VideoContainer">
            <partial name="_VideoCards" model="Model.Videos" />
        </div>

        @if (Model.Videos.HasNextPage)
        {
            <div class="text-center mt-5 mb-5">
                <button id="loadMore" class="btn btn-outline-light rounded-pill px-5" 
                        data-page="@(Model.Videos.PageIndex + 1)" 
                        data-query="@Model.Query">
                    Load More
                </button>
            </div>
        }
    }
    else
    {
        <div class="mt-4 text-secondary">
            No videos found matching your search.
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#loadMore").click(function () {
                var btn = $(this);
                var nextPage = btn.data("page");
                var searchQuery = btn.data("query");

                $.ajax({
                    url: '@Url.Action("Search", "Home")',
                    type: 'GET',
                    data: { query: searchQuery, page: nextPage },
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (data) {
                        if (data.trim() !== "") {
                            $("#VideoContainer").append(data);
                            btn.data("page", nextPage + 1);
                        } else {
                            btn.hide();
                        }
                    }
                });
            });
        });
    </script>
}
