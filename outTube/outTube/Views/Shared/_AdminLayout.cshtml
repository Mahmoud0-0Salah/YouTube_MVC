@using outTube.Models.Enums
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Platform Admin - OurTube</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        :root {
            --bg-main: #0f0f0f;
            --bg-sidebar: #1e1e1e;
            --bg-surface: #282828;
            --text-primary: #ffffff;
            --text-secondary: #aaaaaa;
            --accent-red: #ff0000;
            --accent-blue: #3ea6ff;
            --border-color: rgba(255, 255, 255, 0.1);
            --sidebar-width: 240px;
            --header-height: 64px;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            font-family: 'Roboto', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* Sidebar Styles */
        .studio-sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--bg-sidebar);
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid var(--border-color);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 18px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            text-decoration: none !important;
            color: var(--text-primary);
        }

        .sidebar-header .material-symbols-outlined {
            color: var(--accent-red);
            font-size: 32px;
        }

        .sidebar-nav {
            padding-top: 12px;
            flex-grow: 1;
        }

        .nav-item {
            padding: 10px 24px;
            display: flex;
            align-items: center;
            gap: 24px;
            color: var(--text-primary);
            text-decoration: none !important;
            transition: all 0.2s;
            font-size: 14px;
            border-left: 3px solid transparent;
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-item.active {
            background: rgba(255, 255, 255, 0.1);
            border-left-color: var(--accent-red);
            color: var(--accent-red);
            font-weight: 500;
        }

        .nav-item .material-symbols-outlined {
            font-size: 24px;
            opacity: 0.9;
        }

        .sidebar-footer {
            padding: 16px;
            border-top: 1px solid var(--border-color);
        }

        /* Top Header */
        .studio-header {
            height: var(--header-height);
            background: var(--bg-main);
            border-bottom: 1px solid var(--border-color);
            position: fixed;
            top: 0;
            right: 0;
            left: var(--sidebar-width);
            z-index: 900;
            display: flex;
            align-items: center;
            padding: 0 32px;
            justify-content: space-between;
        }

        .topbar-search {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            display: flex;
            align-items: center;
            padding: 6px 16px;
            width: 400px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(8px);
        }

        .topbar-search:focus-within {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 1px var(--accent-blue);
            width: 440px;
        }

        .topbar-search input {
            background: transparent;
            border: none;
            color: white;
            padding: 4px 12px;
            width: 100%;
            outline: none;
            font-size: 14px;
        }

        .topbar-search .material-symbols-outlined {
            color: var(--text-secondary);
            font-size: 20px;
            transition: color 0.2s;
        }

        .topbar-search:focus-within .material-symbols-outlined {
            color: var(--accent-blue);
        }

        /* Main Content */
        .studio-main {
            margin-left: var(--sidebar-width);
            margin-top: var(--header-height);
            padding: 32px;
            min-height: calc(100vh - var(--header-height));
        }

        /* Generic Studio Components */
        .studio-card {
            background: var(--bg-sidebar);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 24px;
            overflow: hidden;
        }

        .card-header {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border-color);
            font-weight: 500;
            font-size: 16px;
            background: transparent;
        }

        .studio-table {
            width: 100%;
            border-collapse: collapse;
        }

        .studio-table th {
            text-align: left;
            padding: 12px 24px;
            color: var(--text-secondary);
            font-size: 12px;
            font-weight: 500;
            text-transform: uppercase;
            border-bottom: 1px solid var(--border-color);
        }

        .studio-table td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            font-size: 14px;
        }

        .studio-table tr:hover {
            background: rgba(255, 255, 255, 0.03);
        }

        .btn-studio-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--accent-blue);
            padding: 8px 16px;
            border-radius: 2px;
            font-size: 13px;
            font-weight: 500;
            text-transform: uppercase;
            transition: all 0.2s;
            text-decoration: none !important;
        }

        .btn-studio-outline:hover {
            background: rgba(62, 166, 255, 0.1);
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }

        /* Modal Customization */
        .modal-content {
            background: var(--bg-sidebar);
            border: 1px solid var(--border-color);
            color: white;
        }

        /* Modern Glassmorphic Components */
        .studio-card-modern {
            background: rgba(30, 30, 30, 0.4);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            margin-bottom: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .studio-card-modern:hover {
            background: rgba(40, 40, 40, 0.5);
            border-color: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .card-header-modern {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 600;
            font-size: 15px;
            color: var(--text-primary);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .stat-card-modern {
            padding: 24px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 4px;
            letter-spacing: -1px;
        }

        .stat-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
        }

        .studio-table-modern th {
            background: rgba(255, 255, 255, 0.02);
            padding: 14px 24px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
        }
    </style>
</head>
<body>
    <div class="studio-sidebar">
        <a asp-controller="Admin" asp-action="Index" class="sidebar-header">
            <span class="material-symbols-outlined">shield_person</span>
            <span class="fw-bold" style="font-size: 18px; letter-spacing: -0.5px;">Platform Admin</span>
        </a>
        <div class="sidebar-nav">
            <a asp-controller="Admin" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Admin" asp-action="Videos" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Videos" ? "active" : "")">
                <span class="material-symbols-outlined">video_library</span>
                <span>Content Manager</span>
            </a>
            <a asp-controller="Admin" asp-action="Users" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                <span class="material-symbols-outlined">group</span>
                <span>User Registry</span>
            </a>
            <a asp-controller="Admin" asp-action="Reports" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")">
                <span class="material-symbols-outlined">policy</span>
                <span>Review Reports</span>
            </a>
        </div>
        <div class="sidebar-footer">
            <a asp-controller="Home" asp-action="Index" class="nav-item" style="gap: 16px;">
                <span class="material-symbols-outlined">open_in_new</span>
                <span>View Website</span>
            </a>
        </div>
    </div>

    <header class="studio-header">
        <div class="d-flex align-items-center">
            <span class="text-secondary small fw-medium">Platform Management Console</span>
        </div>
    </header>

    <main class="studio-main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
