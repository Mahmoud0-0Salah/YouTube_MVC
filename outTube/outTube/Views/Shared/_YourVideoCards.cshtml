@using ourTube.ViewModels
@using ourTube.ViewModels.Video
@model PaginatedList<VideoGetViewModel>

@foreach (var video in Model)
{
    <div class="video-card" id="video-card-@video.Id">
        <a href="/Video/Details/@video.Id">
            <div class="thumbnail-container">
                <img src="@video.Thumb" alt="Thumbnail for @video.Title" class="thumbnail" loading="lazy" />
                <div class="duration">@video.Duration</div>
            </div>
        </a>
        <div class="video-info">
            <a href="#">
                <img src="@video.Avatar" alt="@video.Channel" class="channel-avatar" loading="lazy" />
            </a>
            <div class="video-details">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <h3 class="video-title" title="@video.Title" style="flex: 1; margin-right: 8px;">@video.Title</h3>
                    <button class="btn btn-sm btn-danger" onclick="deleteVideo('@video.Id'); event.preventDefault(); event.stopPropagation();" title="Delete Video" style="border: none; background: transparent; color: #ff4d4d; cursor: pointer; padding: 4px;">
                        <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                    </button>
                </div>
                <a href="#" class="channel-name" title="@video.Channel">@video.Channel</a>
                <div class="video-meta">
                    <span>@video.Views</span> &bull; <span>@video.Time</span>
                </div>
            </div>
        </div>
    </div>
}