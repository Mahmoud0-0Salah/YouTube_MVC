@using Microsoft.AspNetCore.Identity
@using outTube.Models
@inject UserManager<User> UserManager
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YouTubeCloneApp</title>
    <!-- Include Google Fonts & Material Symbols for Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/YouTubeCloneApp.styles.css" asp-append-version="true" />

    <style>
            /* Modern CSS Variables for Light / Dark Mode */
            :root {
                /* Light Theme Variables */
                --bg-color: #f9f9f9;
                --nav-bg: #ffffff;
                --text-color: #0f0f0f;
                --text-secondary: #606060;
                --border-color: #e5e5e5;
                --hover-bg: #f2f2f2;
                --search-bg: #ffffff;
                --search-border: #ccc;
                --icon-color: #020202;
                --chip-bg: #f2f2f2;
                --chip-hover: #e5e5e5;
                --badge-bg: rgba(0,0,0,0.8);
                --badge-text: #fff;
            }

            [data-theme="dark"] {
                /* Dark Theme Variables */
                --bg-color: #0f0f0f;
                --nav-bg: #0f0f0f;
                --text-color: #f1f1f1;
                --text-secondary: #aaaaaa;
                --border-color: #3f3f3f;
                --hover-bg: #272727;
                --search-bg: #121212;
                --search-border: #303030;
                --icon-color: #ffffff;
                --chip-bg: #272727;
                --chip-hover: #3f3f3f;
                --badge-bg: rgba(0,0,0,0.8);
                --badge-text: #fff;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Roboto', Arial, sans-serif;
                background-color: var(--bg-color);
                color: var(--text-color);
                transition: background-color 0.3s, color 0.3s;
                overflow-x: hidden;
            }

            header.youtube-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 16px;
                height: 56px;
                background-color: var(--nav-bg);
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 100;
            }

            .nav-left, .nav-right {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .menu-btn {
                background: none;
                border: none;
                color: var(--icon-color);
                cursor: pointer;
                padding: 8px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .menu-btn:hover { background-color: var(--hover-bg); }

            .logo {
                display: flex;
                align-items: center;
                font-size: 20px;
                font-weight: 700;
                text-decoration: none !important;
                color: var(--text-color);
                letter-spacing: -1px;
            }
            .logo span.material-symbols-outlined { color: #ff0000; font-size: 28px; margin-right: 4px; }
        
            /* Reset any bootstrap link colors in sidebar */
            .sidebar a {
                color: var(--text-color);
                text-decoration: none !important;
            }
        
            .sidebar-title {
                padding: 8px 24px;
                font-size: 14px;
                font-weight: 500;
                color: var(--text-color);
                text-transform: none;
            }

            .nav-center {
                display: flex;
                flex: 1;
                max-width: 600px;
                margin: 0 20px;
            }

            .search-form {
                display: flex;
                flex: 1;
            }

            .search-input {
                flex: 1;
                padding: 2px 16px;
                height: 40px;
                font-size: 16px;
                border: 1px solid var(--search-border);
                border-radius: 20px 0 0 20px;
                background-color: var(--search-bg);
                color: var(--text-color);
                outline: none;
            }
            .search-input:focus { border-color: #1c62b9; }

            .search-btn {
                width: 64px;
                height: 40px;
                background-color: var(--hover-bg);
                border: 1px solid var(--search-border);
                border-left: none;
                border-radius: 0 20px 20px 0;
                cursor: pointer;
                color: var(--icon-color);
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .search-btn:hover { background-color: var(--border-color); }

            .mic-btn {
                background-color: var(--hover-bg);
                border: none;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                margin-left: 10px;
                cursor: pointer;
                color: var(--icon-color);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .profile-img {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                object-fit: cover;
                cursor: pointer;
            }

            /* --- SIDEBAR --- */
            .main-layout {
                display: flex;
                margin-top: 56px;
            }

            .sidebar {
                width: 240px;
                background-color: var(--bg-color);
                height: calc(100vh - 56px);
                position: fixed;
                overflow-y: auto;
                padding-right: 12px;
                padding-bottom: 20px;
                transition: transform 0.3s ease-in-out;
                z-index: 95;
            }
            .sidebar::-webkit-scrollbar { width: 8px; }
            .sidebar::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }
            .sidebar:hover::-webkit-scrollbar-thumb { background: #717171; }

            /* Sidebar Toggle Classes */
            .sidebar.collapsed {
                transform: translateX(-240px);
            }
            .content {
                margin-left: 240px;
                padding: 0 24px 24px 24px;
                flex: 1;
                background-color: var(--bg-color);
                min-height: calc(100vh - 56px);
                transition: margin-left 0.3s ease-in-out, padding 0.3s ease-in-out;
            }
            .content.full-width {
                margin-left: 0;
                padding: 0 16px 24px 16px;
            }

            .sb-link {
                display: flex;
                align-items: center;
                padding: 10px 12px;
                margin: 0 12px;
                text-decoration: none !important;
                color: var(--text-color);
                border-radius: 10px;
                font-size: 14px;
                font-weight: 500;
            }
            .sb-link:hover { background-color: var(--hover-bg); color: var(--text-color); }
            .sb-link .material-symbols-outlined { margin-right: 20px; font-weight: 300; }
            .sb-link.active { background-color: var(--hover-bg); font-weight: 700; }
            .sb-link.active .material-symbols-outlined { font-variation-settings: ''FILL'' 1; }

            .sidebar-section {
                padding: 12px 0;
                border-bottom: 1px solid var(--border-color);
            }
            .sidebar-section:last-child { border-bottom: none; }

            .sidebar-title {
                padding: 8px 24px;
                font-size: 16px;
                font-weight: 500;
                color: var(--text-color);
            }
    </style>
</head>
<body>
    <header class="youtube-header">
        <div class="nav-left">
            <button class="menu-btn" onclick="toggleSidebar()" title="Menu">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <a asp-controller="Home" asp-action="Index" class="logo" title="YouTube Home">
                <span class="material-symbols-outlined"><img width="50px" src="/Site_Images/logo.png"></span>
                OurTube
            </a>
        </div>

        <div class="nav-center">
            <form class="search-form" asp-controller="Home" asp-action="Search" method="GET">
                <input type="text" name="query" class="search-input" placeholder="Search" aria-label="Search" />
                <button type="submit" class="search-btn" title="Search">
                    <span class="material-symbols-outlined">search</span>
                </button>
            </form>
            <button class="mic-btn" title="Search with your voice">
                <span class="material-symbols-outlined">mic</span>
            </button>
        </div>

        <div class="nav-right">
            <button class="menu-btn" onclick="toggleTheme()" title="Toggle Dark/Light Mode">
                <span class="material-symbols-outlined" id="theme-icon">light_mode</span>
            </button>

            @if (User.Identity.IsAuthenticated)
            {
                var currentUser = await UserManager.GetUserAsync(User);
                var defaultImg = "https://ui-avatars.com/api/?name=" + (currentUser?.UserName ?? "User") + "&background=random";
                var userImg = string.IsNullOrWhiteSpace(currentUser?.ImageUrl) ? defaultImg : currentUser.ImageUrl;

                <form asp-action="Create" asp-controller="Video" method="get">
                    <button class="menu-btn" title="Create">
                        <span class="material-symbols-outlined">video_call</span>
                    </button>
                </form>
                <button class="menu-btn" title="Notifications">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                
                <a asp-controller="Profile" asp-action="Index">
                    <img src="@userImg" 
                         alt="Profile" class="profile-img" id="layout-profile-img" 
                         onerror="this.src='@defaultImg'" />
                </a>
                
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="menu-btn" title="Logout">
                        <span class="material-symbols-outlined">logout</span>
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-auth btn-login" style="text-decoration:none !important; border: 1px solid #3ea6ff; color: #3ea6ff; border-radius: 20px; padding: 5px 15px; display: flex; align-items: center; gap: 8px;">
                    <span class="material-symbols-outlined">account_circle</span>
                    Sign In
                </a>
            }
        </div>
    </header>

    <div class="main-layout">
        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-section">
                <a asp-controller="Home" asp-action="Index" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <span class="material-symbols-outlined">home</span>Home
                </a>
                <!-- <a href="#" class="sb-link">
                    <span class="material-symbols-outlined">app_shortcut</span>Shorts
                </a> -->
            @if (User.Identity.IsAuthenticated)
            {
                <div class="sidebar-section">
                    <a asp-controller="Subscription" asp-action="GetSubscripedVideos"  class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "GetSubscripedVideos" ? "active" : "")">
                        <span class="material-symbols-outlined">subscriptions</span>Subscriptions
                    </a>
                </div>
                
                <div class="sidebar-section">
                    <h3 class="sidebar-title">You</h3>
                    <a  asp-controller="Video" asp-action="YourHistory" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "YourHistory" ? "active" : "")">
                        <span class="material-symbols-outlined">history</span>History
                    </a>
                    <a asp-controller="Video" asp-action="YourVideos" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "YourVideos" ? "active" : "")">
                        <span class="material-symbols-outlined">smart_display</span>Your videos
                    </a>
                    <a asp-controller="Like" asp-action="GetLikedVideos"  class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "GetLikedVideos" ? "active" : "")">
                        <span class="material-symbols-outlined">thumb_up</span>Liked videos
                    </a>
                    <a asp-controller="Home" asp-action="Privacy" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")">
                        <span class="material-symbols-outlined">privacy_tip</span>Privacy
                    </a>
                </div>
            }
            else
            {
                <div class="sidebar-section" style="padding: 16px 24px;">
                    <p style="font-size: 14px; margin-bottom: 12px;">Sign in to like videos, comment, and subscribe.</p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-login" style="border: 1px solid #3ea6ff; color: #3ea6ff; border-radius: 20px; padding: 5px 15px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                        <span class="material-symbols-outlined">account_circle</span> Sign In
                    </a>
                </div>
            }
            
            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-section">
                    <a asp-controller="Admin" asp-action="Index" class="sb-link">
                        <span class="material-symbols-outlined">admin_panel_settings</span>Admin Dashboard
                    </a>
                </div>
            }
            
            <div class="sidebar-section">
                <h3 class="sidebar-title">Explore</h3>
                <a asp-controller="Home" asp-action="Trending" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Trending" ? "active" : "")">
                    <span class="material-symbols-outlined">local_fire_department</span>Trending
                </a>
                <a asp-controller="Home" asp-action="Lastest" class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Lastest" ? "active" : "")">
                    <span class="material-symbols-outlined">schedule</span>Lastest
                </a>
                <!-- <a href="#" class="sb-link">
                    <span class="material-symbols-outlined">music_note</span>Music
                </a>
                <a href="#" class="sb-link">
                    <span class="material-symbols-outlined">sports_esports</span>Gaming
                </a>
                <a href="#" class="sb-link">
                    <span class="material-symbols-outlined">news</span>News
                </a>
                <a href="#" class="sb-link">
                    <span class="material-symbols-outlined">emoji_events</span>Sports
                </a> -->
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="content" id="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            // Sidebar Toggle Logic
            function toggleSidebar() {
                const sidebar = document.getElementById('sidebar');
                const content = document.getElementById('main-content');
            
                sidebar.classList.toggle('collapsed');
                content.classList.toggle('full-width');
            
                // Save state
                localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('collapsed'));
            }

            // Toggle Theme Logic
            function toggleTheme() {
                const htmlTag = document.documentElement;
                const themeIcon = document.getElementById('theme-icon');
            
                if (htmlTag.getAttribute('data-theme') === 'dark') {
                    htmlTag.setAttribute('data-theme', 'light');
                    themeIcon.textContent = 'dark_mode'; // Switch icon
                    localStorage.setItem('theme', 'light');
                } else {
                    htmlTag.setAttribute('data-theme', 'dark');
                    themeIcon.textContent = 'light_mode'; // Switch icon
                    localStorage.setItem('theme', 'dark');
                }
            }

            // Initialize theme and sidebar from local storage
            document.addEventListener("DOMContentLoaded", () => {
                // Theme
                const savedTheme = localStorage.getItem('theme') || 'dark';
                const htmlTag = document.documentElement;
                const themeIcon = document.getElementById('theme-icon');
            
                htmlTag.setAttribute('data-theme', savedTheme);
                if(savedTheme === 'dark') {
                    themeIcon.textContent = 'light_mode';
                } else {
                    themeIcon.textContent = 'dark_mode';
                }

                // Sidebar
                const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
                if (isCollapsed) {
                    document.getElementById('sidebar').classList.add('collapsed');
                    document.getElementById('main-content').classList.add('full-width');
                }
            });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
