@model outTube.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Join OurTube";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Join OurTube</h2>
            <p>Create an account to start sharing your stories</p>
        </div>
        
        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-input" placeholder="First Name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-input" placeholder="Last Name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" class="form-input" placeholder="User Name" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" placeholder="Email Address" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DateOfBirth"></label>
                <input asp-for="DateOfBirth" class="form-input" id="birth-picker" placeholder="Select Date of Birth" type="text" />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-input" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-input" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary auth-submit">Sign Up</button>
        </form>

        <script>
            document.addEventListener("DOMContentLoaded", function() {
                flatpickr("#birth-picker", {
                    dateFormat: "Y-m-d",
                    maxDate: "today",
                    theme: "dark",
                    disableMobile: "true"
                });
            });
        </script>

        <div class="auth-footer">
            <p>Already have an account? <a asp-action="Login">Sign In</a></p>
        </div>
    </div>
</div>

<style>
/* Modern Auth Styles */
.auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    padding: 2rem;
}

.auth-card {
    background: var(--card-bg, #1a1a1a);
    color: #fff;
    padding: 2.5rem;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    width: 100%;
    max-width: 500px;
    border: 1px solid rgba(255,255,255,0.1);
}

.auth-header {
    text-align: center;
    margin-bottom: 2rem;
}

.auth-header h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(90deg, #ff0000, #ff5555);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.auth-header p {
    color: #999;
}

.auth-form .form-group {
    margin-bottom: 1.25rem;
}

.auth-form label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: #ccc;
}

.form-input {
    width: 100%;
    padding: 0.8rem 1rem;
    background: #000;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 0.75rem;
    color: #fff;
    outline: none;
    transition: all 0.3s;
}

.form-input:focus {
    border-color: #ff0000;
    box-shadow: 0 0 0 2px rgba(255,0,0,0.2);
}

.form-row {
    display: flex;
    gap: 1rem;
}

.form-row .form-group {
    flex: 1;
}

.btn-primary.auth-submit {
    width: 100%;
    margin-top: 1rem;
    padding: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 0.75rem;
    background: #ff0000;
    border: none;
    color: #fff;
    cursor: pointer;
    transition: transform 0.2s, background 0.2s;
}

.btn-primary.auth-submit:hover {
    background: #cc0000;
    transform: translateY(-2px);
}

.auth-footer {
    text-align: center;
    margin-top: 1.5rem;
    color: #999;
}

.auth-footer a {
    color: #ff0000;
    text-decoration: none;
    font-weight: 600;
}

.auth-footer a:hover {
    text-decoration: underline;
}

.text-danger {
    color: #ff4444;
    font-size: 0.85rem;
    margin-top: 0.25rem;
    display: block;
}
</style>
