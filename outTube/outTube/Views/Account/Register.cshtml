@model outTube.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Join OurTube";
}

<div class="auth-wrapper">
    <div class="auth-card-glass wide">
        <div class="auth-brand">
            <span class="material-symbols-outlined">play_circle</span>
            <h1>OurTube</h1>
        </div>
        
        <div class="auth-header">
            <h2>Create Account</h2>
            <p>Join our community of creators and viewers</p>
        </div>
        
        <form asp-action="Register" method="post" class="auth-form-modern">
            <div asp-validation-summary="ModelOnly" class="auth-alert mb-4"></div>
            
            <div class="form-row mb-3">
                <div class="form-floating-custom flex-grow-1">
                    <input asp-for="FirstName" class="input-modern" placeholder=" " />
                    <label asp-for="FirstName">First Name</label>
                    <span asp-validation-for="FirstName" class="error-text"></span>
                </div>
                <div class="form-floating-custom flex-grow-1">
                    <input asp-for="LastName" class="input-modern" placeholder=" " />
                    <label asp-for="LastName">Last Name</label>
                    <span asp-validation-for="LastName" class="error-text"></span>
                </div>
            </div>

            <div class="form-floating-custom mb-3">
                <input asp-for="UserName" class="input-modern" placeholder=" " />
                <label asp-for="UserName">Username</label>
                <span asp-validation-for="UserName" class="error-text"></span>
            </div>

            <div class="form-floating-custom mb-3">
                <input asp-for="Email" class="input-modern" placeholder=" " />
                <label asp-for="Email">Email Address</label>
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <div class="form-floating-custom mb-3">
                <input asp-for="DateOfBirth" class="input-modern" id="birth-picker" placeholder=" " readonly />
                <label asp-for="DateOfBirth">Date of Birth</label>
                <span asp-validation-for="DateOfBirth" class="error-text"></span>
            </div>

            <div class="form-row mb-4">
                <div class="form-floating-custom flex-grow-1">
                    <input asp-for="Password" type="password" class="input-modern" placeholder=" " />
                    <label asp-for="Password">Password</label>
                    <span asp-validation-for="Password" class="error-text"></span>
                </div>
                <div class="form-floating-custom flex-grow-1">
                    <input asp-for="ConfirmPassword" type="password" class="input-modern" placeholder=" " />
                    <label asp-for="ConfirmPassword">Confirm</label>
                    <span asp-validation-for="ConfirmPassword" class="error-text"></span>
                </div>
            </div>

            <button type="submit" class="btn-auth-primary">
                <span>Sign Up</span>
                <span class="material-symbols-outlined">person_add</span>
            </button>
        </form>

        <div class="auth-divider">
            <span>OR</span>
        </div>

        <div class="auth-footer-text">
            Already have an account? <a asp-action="Login">Sign In</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        flatpickr("#birth-picker", {
            dateFormat: "Y-m-d",
            maxDate: "today",
            theme: "dark",
            disableMobile: "true",
            onOpen: function(selectedDates, dateStr, instance) {
                instance.calendarContainer.classList.add("modern-picker");
            }
        });
    });
</script>

<style>
/* Auth theme variables - Dark (default) */
[data-theme="dark"] .auth-wrapper,
.auth-wrapper {
    --auth-bg: #0f0f0f;
    --card-bg: rgba(30, 30, 30, 0.85);
    --card-border: rgba(255, 255, 255, 0.1);
    --accent-red: #ff0000;
    --accent-blue: #3ea6ff;
    --auth-text: #ffffff;
    --auth-text-dim: #aaaaaa;
    --auth-input-bg: rgba(0, 0, 0, 0.3);
    --auth-input-border: rgba(255, 255, 255, 0.1);
    --auth-divider: rgba(255, 255, 255, 0.1);
    --auth-gradient-start: #1a1a1a;
    --auth-gradient-end: #0f0f0f;
    --auth-shadow: rgba(0, 0, 0, 0.5);
}

/* Auth theme variables - Light */
[data-theme="light"] .auth-wrapper {
    --auth-bg: #f9f9f9;
    --card-bg: rgba(255, 255, 255, 0.95);
    --card-border: rgba(0, 0, 0, 0.1);
    --accent-red: #ff0000;
    --accent-blue: #065fd4;
    --auth-text: #0f0f0f;
    --auth-text-dim: #606060;
    --auth-input-bg: rgba(0, 0, 0, 0.04);
    --auth-input-border: rgba(0, 0, 0, 0.15);
    --auth-divider: rgba(0, 0, 0, 0.1);
    --auth-gradient-start: #f0f0f0;
    --auth-gradient-end: #f9f9f9;
    --auth-shadow: rgba(0, 0, 0, 0.15);
}

.auth-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
    background: radial-gradient(circle at center, var(--auth-gradient-start) 0%, var(--auth-gradient-end) 100%);
    padding: 20px;
}

.auth-card-glass {
    background: var(--card-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 40px;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 25px 50px -12px var(--auth-shadow);
    animation: fadeInScale 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.auth-card-glass.wide {
    max-width: 540px;
}

@@keyframes fadeInScale {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

.auth-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
}

.auth-brand .material-symbols-outlined {
    font-size: 48px;
    color: var(--accent-red);
}

.auth-brand h1 {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin: 0;
    color: var(--auth-text);
}

.auth-header {
    text-align: center;
    margin-bottom: 24px;
}

.auth-header h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--auth-text);
}

.auth-header p {
    color: var(--auth-text-dim);
    font-size: 14px;
}

.form-row {
    display: flex;
    gap: 16px;
}

/* Form Styles */
.form-floating-custom {
    position: relative;
    display: flex;
    flex-direction: column;
}

.input-modern {
    background: var(--auth-input-bg);
    border: 1px solid var(--auth-input-border);
    border-radius: 12px;
    padding: 24px 16px 8px 16px;
    color: var(--auth-text);
    font-size: 15px;
    outline: none;
    transition: all 0.2s;
    width: 100%;
}

.form-floating-custom label {
    position: absolute;
    left: 16px;
    top: 16px;
    color: var(--auth-text-dim);
    font-size: 15px;
    pointer-events: none;
    transition: all 0.2s;
}

.input-modern:focus + label, .input-modern:not(:placeholder-shown) + label {
    top: 6px;
    font-size: 11px;
    color: var(--accent-blue);
    font-weight: 600;
}

.input-modern:focus, .input-modern:not(:placeholder-shown) {
    border-color: var(--accent-blue);
    background: var(--auth-input-bg);
}

.error-text {
    color: #ff4e4e;
    font-size: 11px;
    margin-top: 4px;
    padding-left: 4px;
}

/* Buttons */
.btn-auth-primary {
    width: 100%;
    background: var(--accent-red);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-auth-primary:hover {
    background: #cc0000;
    transform: translateY(-1px);
    box-shadow: 0 8px 16px -4px rgba(255, 0, 0, 0.3);
}

.auth-divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 20px 0;
    color: var(--auth-divider);
}

.auth-divider::before, .auth-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--auth-divider);
}

.auth-divider span {
    padding: 0 16px;
    font-size: 12px;
    font-weight: 600;
    color: var(--auth-text-dim);
}

.auth-footer-text {
    text-align: center;
    font-size: 14px;
    color: var(--auth-text-dim);
}

.auth-footer-text a {
    color: var(--accent-blue);
    text-decoration: none;
    font-weight: 600;
    margin-left: 4px;
}

/* Alert Box */
.auth-alert {
    background: rgba(255, 78, 78, 0.1);
    border: 1px solid rgba(255, 78, 78, 0.2);
    border-radius: 12px;
    padding: 12px 16px;
    color: #ff4e4e;
    font-size: 13px;
}

.auth-alert ul { margin: 0; padding: 0; list-style: none; }
</style>
